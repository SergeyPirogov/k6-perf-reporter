{
  "_comment_datasource": "Supported values: influxdb (default), victoriametrics, prometheus",
  "dataSource": "influxdb",

  "_comment_influx": "Used when dataSource = influxdb",
  "influx": {
    "url": "http://localhost:8086",
    "token": "${INFLUX_TOKEN}",
    "org": "my-org",
    "bucket": "k6"
  },

  "_comment_vm": "Used when dataSource = victoriametrics",
  "victoriametrics": {
    "url": "http://localhost:8428",
    "token": "${VM_TOKEN}"
  },

  "slack": {
    "token": "${SLACK_TOKEN}",
    "channel": "#k6-reports"
  },
  "cache": {
    "ttl": 3600
  },
  "_comment_grafana": "Optional Grafana dashboard link included in reports (env: GRAFANA_DASHBOARD_URL)",
  "grafana": {
    "dashboardUrl": "https://grafana.example.com/d/abc123/k6-dashboard"
  }
}
