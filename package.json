{
  "name": "k6-perf-reporter",
  "version": "1.0.0",
  "description": "Reporting tool for k6 performance tests with InfluxDB 2 integration",
  "main": "dist/index.js",
  "bin": {
    "k6-perf-reporter": "dist/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/SergeyPirogov/k6-perf-reporter.git"
  },
  "keywords": ["k6", "performance", "testing", "influxdb", "reporting", "cli"],
  "author": "Sergey Pirogov",
  "license": "MIT",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "report": "tsx src/cli.ts",
    "report:example": "tsx src/cli.ts generate --run-id '961989' -st '-5h' --format cli",
    "report:markdown": "tsx src/cli.ts generate --format markdown",
    "report:ai": "tsx src/cli.ts generate --ai",
    "lint": "eslint src",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "bash scripts/setup-hooks.sh 2>/dev/null || true"
  },
  "dependencies": {
    "@influxdata/influxdb-client": "^1.33.2",
    "chalk": "^5.3.0",
    "commander": "^11.1.0",
    "puppeteer": "^21.6.1",
    "table": "^6.8.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.3"
  },
  "files": ["dist"],
  "engines": {
    "node": ">=16.0.0"
  }
}

