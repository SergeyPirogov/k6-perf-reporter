{
  "name": "k6-perf-reporter",
  "version": "1.5.0",
  "description": "Reporting tool for k6 performance tests with InfluxDB 2 integration",
  "license": "MIT",
  "main": "dist/index.js",
  "bin": {
    "k6-reporter": "dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "report": "tsx src/cli.ts",
    "report:example": "tsx src/cli.ts generate --run-id '965375' -st '-24h'",
    "report:example:json": "tsx src/cli.ts generate --run-id '964900' -st '-4h' --format json",
    "lint": "eslint src",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@influxdata/influxdb-client": "^1.33.2",
    "chalk": "^5.3.0",
    "commander": "^11.1.0",
    "table": "^6.8.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^8.56.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
